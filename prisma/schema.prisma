// Prisma Schema for InventoryOS
// Run: npx prisma migrate dev --name init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────
// Auth
// ─────────────────────────────────────────

enum Role {
  ADMIN
  MANAGER
  STAFF
}

model User {
  id           String          @id @default(cuid())
  email        String          @unique
  passwordHash String
  name         String
  role         Role            @default(STAFF)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  movements    StockMovement[]

  @@map("users")
}

// ─────────────────────────────────────────
// Inventory
// ─────────────────────────────────────────

enum ProductStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum MovementType {
  receive
  issue
  transfer
  adjust
}

model Category {
  id        String    @id @default(cuid())
  name      String    @unique
  createdAt DateTime  @default(now())
  products  Product[]

  @@map("categories")
}

model Product {
  id           String          @id @default(cuid())
  sku          String          @unique
  name         String
  description  String?
  status       ProductStatus   @default(ACTIVE)
  costPrice    Decimal         @db.Decimal(10, 2)
  sellPrice    Decimal         @db.Decimal(10, 2)
  currentQty   Int             @default(0)
  minQty       Int             @default(0)
  maxQty       Int             @default(0)
  unit         String          @default("pcs")
  locationZone String          @default("")
  locationRack String          @default("")
  locationBin  String          @default("")
  categoryId   String?
  category     Category?       @relation(fields: [categoryId], references: [id])
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  movements    StockMovement[]

  @@map("products")
}

model StockMovement {
  id           String       @id @default(cuid())
  type         MovementType
  productId    String
  product      Product      @relation(fields: [productId], references: [id])
  qty          Int
  fromLocation String?
  toLocation   String?
  operatorId   String?
  operator     User?        @relation(fields: [operatorId], references: [id])
  referenceId  String       @default("")
  note         String?
  timestamp    DateTime     @default(now())

  @@index([productId])
  @@index([timestamp])
  @@map("stock_movements")
}
